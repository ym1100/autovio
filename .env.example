# ViraGen Environment Configuration

# MongoDB Configuration
# Option 1: Full connection string (includes credentials)
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/viragen

# Option 2: Separate credentials (recommended for security)
MONGODB_URI=mongodb://localhost:27017
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_DB_NAME=viragen
MONGODB_AUTH_SOURCE=admin

# Backend server port (optional, defaults to 3001)
PORT=3001

# Data directory for binary files (optional, defaults to packages/backend/data)
# VIRAGEN_DATA_DIR=/path/to/data

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Default admin user for migration (optional)
DEFAULT_ADMIN_EMAIL=admin@viragen.local
DEFAULT_ADMIN_PASSWORD=changeme123
DEFAULT_ADMIN_NAME=Admin
