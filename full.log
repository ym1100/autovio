@viragen/backend dev: {
@viragen/backend dev:   "scene_index": <number>,
@viragen/backend dev:   "duration_seconds": <number> (length of this scene in seconds; all scenes' duration_seconds should add up to the target total if one was given),
@viragen/backend dev:   "image_prompt": "<detailed prompt for image generation>",
@viragen/backend dev:   "negative_prompt": "<what to avoid>",
@viragen/backend dev:   "video_prompt": "<camera/motion description for image-to-video>",
@viragen/backend dev:   "text_overlay": "<text to show, if any>",
@viragen/backend dev:   "transition": "<transition to next scene>"
@viragen/backend dev: }
